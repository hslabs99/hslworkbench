# Copy to .env.local — .env.local is gitignored (*.local)

# Required for Microsoft sign-in in the browser (Vite exposes VITE_* vars only)
VITE_MS_TENANT_ID=
VITE_MS_CLIENT_ID=
VITE_MS_REDIRECT_URI=http://localhost:5173/auth/microsoft/callback
# App Hosting: set VITE_MS_TENANT_ID and VITE_MS_CLIENT_ID in apphosting.yaml (BUILD).
# Redirect URI can be omitted on hosting — app uses {origin}/auth/microsoft/callback.
# Register that URI in Azure Entra → App registration → Authentication (SPA).
# OpenAI — loaded from Google Secret Manager (openaiApiKey), not from this file.
# Local dev: gcloud auth application-default login
# Optional override only (normally leave unset):
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — reserved for a future backend; not used by SPA sign-in today
MS_CLIENT_SECRET=

# CELGPS → Supabase migration (dev server only; see .env.celgps-migration.local)
# CELGPS_SUPABASE_PASSWORD=
